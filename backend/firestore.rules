rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── articles collection ──────────────────────────────────────────
    match /articles/{articleId} {

      // Anyone can read articles (no auth required for v1)
      allow read: if true;

      // Anyone can create articles, but the document must pass schema validation
      allow create: if isValidArticle(request.resource.data);

      // No updates or deletes in v1 (articles are immutable once published)
      allow update, delete: if false;
    }

    // ── Schema validation function ───────────────────────────────────
    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'description', 'content', 'author', 'thumbnailURL', 'createdAt'])
        && data.keys().hasOnly(['title', 'description', 'content', 'author', 'thumbnailURL', 'createdAt'])
        // Type checks
        && data.title is string
        && data.description is string
        && data.content is string
        && data.author is string
        && data.thumbnailURL is string
        && data.createdAt is timestamp
        // Length constraints
        && data.title.size() >= 1 && data.title.size() <= 200
        && data.description.size() >= 1 && data.description.size() <= 500
        && data.content.size() >= 1 && data.content.size() <= 10000
        && data.author.size() >= 1 && data.author.size() <= 100
        // thumbnailURL must be a non-empty string (full URL validation not possible in rules)
        && data.thumbnailURL.size() >= 1
        // createdAt must be the server timestamp (prevents client clock manipulation)
        && data.createdAt == request.time;
    }

    // ── ai_insights collection (AI-generated article analysis cache) ─
    match /ai_insights/{insightId} {

      // Anyone can read cached insights (public, non-sensitive data)
      allow read: if true;

      // Anyone can create insights (generated by Gemini, keyed by URL hash)
      // No auth required — insights are deterministic per article URL
      allow create: if isValidInsight(request.resource.data);

      // No updates or deletes — cache entries are immutable
      allow update, delete: if false;
    }

    // ── AI insight schema validation ─────────────────────────────────
    function isValidInsight(data) {
      return data.keys().hasAll(['summaryBullets', 'tone', 'toneExplanation', 'sourceContext', 'emphasisAnalysis'])
        && data.tone is string
        && data.toneExplanation is string
        && data.sourceContext is string
        && data.emphasisAnalysis is string
        && data.summaryBullets is list
        && data.tone.size() >= 1 && data.tone.size() <= 50
        && data.toneExplanation.size() >= 1 && data.toneExplanation.size() <= 2000
        && data.sourceContext.size() >= 1 && data.sourceContext.size() <= 2000
        && data.emphasisAnalysis.size() >= 1 && data.emphasisAnalysis.size() <= 2000
        && data.summaryBullets.size() >= 1 && data.summaryBullets.size() <= 10;
    }

    // ── Deny all other collections ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
